# URL backend FastAPI (lihat backend/app/main.py & .env backend)
VITE_API_URL=http://localhost:8001/api/v1

# ── Midtrans (Payment Gateway) ──────────────────────────────────────────
# PENTING: cuma Client Key (public, aman di frontend) yang taruh di sini.
# Server Key & Merchant ID JANGAN di sini — taruh di backend/.env saja,
# karena dipakai untuk create-transaction & verifikasi signature di server.

# Toggle environment aktif: "sandbox" (testing) atau "production"
VITE_MIDTRANS_ENV=sandbox

# Client Key — ambil dari dashboard.midtrans.com > Settings > Access Keys
# (beda nilai tiap kamu switch toggle mode Sandbox/Production di dashboard)
VITE_MIDTRANS_CLIENT_KEY_SANDBOX=
VITE_MIDTRANS_CLIENT_KEY_PRODUCTION=