# =============================================
# PDF Intelligence App - Environment Config
# =============================================

# --- Database (MySQL via Laragon) ---
# Format: mysql+aiomysql://user:password@host:port/dbname
# Laragon default: user=root, password kosong
DATABASE_URL=mysql+aiomysql://root:@localhost:3306/pdf_intelligence
SYNC_DATABASE_URL=mysql+pymysql://root:@localhost:3306/pdf_intelligence

# --- Security ---
SECRET_KEY=ganti-ini-dengan-string-acak-minimal-32-karakter
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- AI Providers ---
GEMINI_API_KEY=isi-api-key-gemini-dari-aistudio.google.com
GROQ_API_KEY=isi-api-key-groq-dari-console.groq.com

# --- AI Model Config ---
GEMINI_MODEL=gemini-3.5-flash
GROQ_MODEL=llama3-70b-8192

# --- Quota ---
FREE_QUOTA_DAILY=5
PRO_QUOTA_DAILY=50
ENTERPRISE_QUOTA_DAILY=500

# --- File Upload ---
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=./uploads

# --- App ---
APP_NAME=PDF Intelligence
APP_ENV=development
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
