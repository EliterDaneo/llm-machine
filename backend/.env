SYNC_DATABASE_URL=mysql+pymysql://root:@localhost:3306/pdf_intelligence

# --- Security ---
SECRET_KEY=sangatrahasiajangandibagikan
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- AI Providers ---
GEMINI_API_KEY=AQ.Ab8RN6LdDdaUzs2Pm_iyuW-SGvFOAjtn-4zCqiBSLKVSUZn1bw
GROQ_API_KEY=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

